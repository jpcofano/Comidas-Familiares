{
  "name": "comidas-familiares",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "bootstrap:config": "tsx scripts/bootstrap-config.ts",
    "seed:firestore": "tsx scripts/seed-firestore.ts",
    "seed:planes": "tsx scripts/seed-planes-prueba.ts",
    "reseed": "tsx scripts/reseed-ingredientes.ts",
    "migrar:unidades": "tsx scripts/migrar-unidades.ts",
    "e9:catalogo": "tsx scripts/update-catalogo-ingredientes.ts",
    "e9:proteinas": "tsx scripts/migrate-proteinas-e9.ts",
    "e9:importador": "tsx scripts/seed-config-importador.ts --force",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "test:all": "vitest run && npm run test:rules"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.10.0",
    "globals": "^17.6.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  }
}
